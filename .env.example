# Client build config (Vite). Copy to `.env.local` for local dev, or set these as
# GitHub repo *variables* so the Pages build embeds them (see deploy.yml).
#
# Both values are PUBLIC (safe to expose in the built site) — no secrets here.
# Leave them BLANK/unset to build the offline-only game (no server calls at all).

# Base URL of the game server (your deployed Cloudflare Worker).
# Local dev points at `wrangler dev`:
VITE_API_URL=http://127.0.0.1:8787

# Google OAuth 2.0 Web client id (Sign in with Google). Leave blank to disable the
# Google button; local e2e uses the dev sign-in bypass instead (window.zfDevSignIn).
VITE_GOOGLE_CLIENT_ID=

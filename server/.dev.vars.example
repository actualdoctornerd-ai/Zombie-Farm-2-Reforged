# Copy to `.dev.vars` (git-ignored) for `wrangler dev`. These mirror the Worker's
# secrets/vars locally.
SESSION_SECRET="dev-only-secret-change-me"
# DEV_AUTH=1 enables the no-Google sign-in bypass (POST /auth {devSub}). Local only.
DEV_AUTH="1"
ALLOWED_ORIGIN="http://localhost:5173"
GOOGLE_CLIENT_ID="dev.apps.googleusercontent.com"
# Server-owned raid cooldown (ms). Default is 2h; use a short value locally so
# testing raids isn't gated. Match the client's fast-mode 60s if desired.
RAID_COOLDOWN_MS="60000"
# Save-import cutoff (epoch ms). Accounts created BEFORE this may import their existing
# save into server-owned state, once per subsystem; newer accounts get fixed server
# defaults. Far-future locally so dev accounts can seed. Unset/0 = imports closed.
MIGRATION_CUTOFF_MS="4102444800000"

# Explicitly opt into cross-account trading in local development only.
BLACK_MARKET_ENABLED="1"

# Raid session TTL (ms). Default 30min; short here so tests can observe an expiry.
RAID_SESSION_TTL_MS="8000"

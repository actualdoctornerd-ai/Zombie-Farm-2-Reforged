{
  "name": "zombiefarm-server",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "description": "Ground-truth save + async friend gifting API (Cloudflare Worker + D1)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:apply:local": "wrangler d1 execute zombiefarm --local --file=./schema.sql",
    "db:apply:remote": "wrangler d1 execute zombiefarm --remote --file=./schema.sql",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
